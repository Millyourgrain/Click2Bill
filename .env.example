# Firebase (required) - Get from Firebase Console → Project Settings → General
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Firebase Cloud Functions region (must match functions/index.js; default us-central1)
# VITE_FUNCTIONS_REGION=us-central1
# Optional: full health URL from Firebase Console → Functions (if default pattern fails)
# VITE_FUNCTIONS_HEALTH_URL=https://us-central1-your-project-id.cloudfunctions.net/health

# Geoapify (optional) - For travel/distance calculator. Get from https://www.geoapify.com/
VITE_GEOAPIFY_API_KEY=your_geoapify_key
