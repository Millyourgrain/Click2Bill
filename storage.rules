// =====================================================================
// FIREBASE STORAGE RULES FOR E-INVOICING PLATFORM
// =====================================================================
//
// HOW TO APPLY:
// Firebase Console → Storage → Rules → replace and Publish
//
// Path structure:
//   logos/{userId}/           - Company/worker logos
//   documents/{userId}/       - Void cheque, insurance, engagement agreements, etc.
//
// =====================================================================

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Path userId = org billing uid (company owner). Team members may read/write that prefix.
    function isOrgMemberForPathOwner(ownerUid) {
      return request.auth != null && (
        request.auth.uid == ownerUid
        || (
          firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
          && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.organizationOwnerId == ownerUid
        )
      );
    }

    match /logos/{userId}/{allPaths=**} {
      allow read, write: if isOrgMemberForPathOwner(userId);
    }

    match /documents/{userId}/{allPaths=**} {
      allow read, write: if isOrgMemberForPathOwner(userId);
    }

    // Wizard uploads before company doc is complete; path userId = org billing uid.
    match /companySetup/{userId}/{allPaths=**} {
      allow read, write: if isOrgMemberForPathOwner(userId);
    }
  }
}
